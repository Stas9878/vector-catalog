# === Qdrant ===
QDRANT_URL=http://localhost:6333
# Для локальной разработки без API key оставьте пустым
QDRANT_API_KEY=

# === Приложение ===
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=dev

# Секрет для подписи cookie-сессий (минимум 32 символа)
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-use-secrets-module

# Tenant по умолчанию для витрины (acme или beta)
DEFAULT_TENANT=acme

# === Embeddings (урок 6.2) ===
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# === PostgreSQL (урок 6.5) ===
DATABASE_URL=postgresql+asyncpg://vector:vector_pass@localhost:5432/vector_catalog
